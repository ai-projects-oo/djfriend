{
  "name": "djfriend",
  "private": true,
  "version": "1.0.16",
  "type": "module",
  "main": "electron-compiled/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "analyze": "tsx src/analyze.ts",
    "bench": "tsx src/bench.ts",
    "clear-results": "rm -f ~/Music/djfriend-results-v3.json && echo 'Cleared cache'",
    "go": "npm run build && npm run preview",
    "clean": "rm -rf dist && rm -f ~/Music/djfriend-results-v3.json && rm -f \"/Users/ozben/Music/Music/Media.localized/Music/results.json\" && echo 'Cleared build cache and results'",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "npm run build && npm run build:electron && npx electron .",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --target=node20 --format=esm --external:electron --external:connect --external:serve-static --external:busboy --external:music-metadata --external:node-id3 --external:essentia.js --external:audio-decode --external:axios --external:dotenv --external:openai --outfile=electron-compiled/main.js",
    "dist": "npm run build && npm run build:electron && electron-packager . DJFriend --platform=darwin --arch=universal --out=release --overwrite --ignore='^/release' --ignore='^/.git' --ignore='^/electron$' --ignore='^/src$'",
    "dist:win": "npm run build && npm run build:electron && electron-packager . DJFriend --platform=win32 --arch=x64 --out=release --overwrite --ignore='^/release' --ignore='^/.git' --ignore='^/electron$' --ignore='^/src$' --executable-name=DJFriend",
    "dist:win:installer": "npm run build && npm run build:electron && electron-builder --win --x64",
    "build:server": "esbuild src/standalone-server.ts --bundle --platform=node --target=node20 --format=esm --external:connect --external:serve-static --external:busboy --external:music-metadata --external:node-id3 --external:essentia.js --external:audio-decode --external:axios --external:dotenv --external:openai --outfile=server-compiled/standalone-server.js",
    "start": "node server-compiled/standalone-server.js"
  },
  "build": {
    "appId": "com.djfriend.app",
    "productName": "DJFriend",
    "afterSign": "afterSign.cjs",
    "mac": {
      "category": "public.app-category.music",
      "icon": "public/icon.icns",
      "artifactName": "DJFriend-${arch}.dmg",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "files": [
      "dist/**",
      "electron-compiled/**",
      "src/**",
      "vite.config.ts",
      "tsconfig*.json",
      "package.json",
      "node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "DJFriend-Setup.exe"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "shortcutName": "DJFriend",
      "runAfterFinish": true
    },
    "directories": {
      "output": "dist_electron"
    },
    "publish": {
      "provider": "github",
      "owner": "ai-projects-oo",
      "repo": "djfriend"
    },
    "asar": true,
    "extraMetadata": {
      "main": "electron-compiled/main.js"
    }
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/busboy": "^1.5.4",
    "audio-decode": "^2.2.3",
    "axios": "^1.6.0",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connect": "^3.7.0",
    "dotenv": "^16.3.1",
    "essentia.js": "^0.1.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "music-metadata": "^11.12.3",
    "node-id3": "^0.2.9",
    "openai": "^6.33.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "serve-static": "^2.2.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/packager": "^19.1.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/connect": "^3.4.38",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/serve-static": "^2.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser": "^4.1.0",
    "autoprefixer": "^10.4.24",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
