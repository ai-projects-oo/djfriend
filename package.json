{
  "name": "djfriend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-compiled/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "analyze": "tsx src/analyze.ts",
    "bench": "tsx src/bench.ts",
    "clear-results": "rm -f ~/Music/djfriend-results-v3.json && echo 'Cleared cache'",
    "go": "npm run build && npm run preview",
    "clean": "rm -rf dist && rm -f ~/Music/djfriend-results-v3.json && rm -f \"/Users/ozben/Music/Music/Media.localized/Music/results.json\" && echo 'Cleared build cache and results'",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "npm run build && tsx electron/main.ts",
    "dist": "npm run build && tsc -p tsconfig.electron.json && electron-builder --mac"
  },
  "build": {
    "appId": "com.djfriend.app",
    "productName": "DJFriend",
    "mac": {
      "category": "public.app-category.music",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "files": [
      "dist/**",
      "electron-compiled/**",
      "src/**",
      "vite.config.ts",
      "tsconfig*.json",
      "package.json",
      "node_modules/**"
    ],
    "asar": false,
    "extraMetadata": {
      "main": "electron-compiled/main.js"
    }
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/busboy": "^1.5.4",
    "audio-decode": "^2.2.3",
    "axios": "^1.6.0",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "essentia.js": "^0.1.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.575.0",
    "music-metadata": "^7.14.0",
    "node-id3": "^0.2.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
